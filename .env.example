# Supabase — get these from https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: site URL for auth callbacks. In Vercel, set to your production URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
